# Optional: override workspace root resolution when running outside repo root.
AGGREGATOR_ROOT=

# Optional: set if OpenClaw CLI is not on PATH.
OPENCLAW_BIN=openclaw

# Optional: used by sync script for route-aware jobs.
OPENCLAW_CHANNEL=
OPENCLAW_TO=

# Optional: set when using push-webhook helpers later.
PUBLIC_BASE_URL=

# Regime-engine S/R ingestion
REGIME_ENGINE_URL=https://regime-engine-production.example.com
REGIME_ENGINE_INGEST_TOKEN=<set-in-openclaw-secret-store>
EMIT_SR_LEVELS_DRY_RUN=false
